# API Configuration
# Leave empty in local development to use the Vite proxy.
# For hosted deployments, set the full API base URL, for example:
# VITE_API_URL=https://api.handoverkey.com/api/v1
VITE_API_URL=

# Optional explicit websocket endpoint for hosted deployments.
# If unset, the app falls back to the current origin with /ws.
# Example:
# VITE_WS_URL=wss://api.handoverkey.com/ws
VITE_WS_URL=
