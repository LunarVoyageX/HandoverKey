# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=handoverkey_dev
DB_USER=postgres
DB_PASSWORD=postgres

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Security Secrets (REQUIRED - generate with: openssl rand -base64 64)
JWT_SECRET=
ACTIVITY_HMAC_SECRET=
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Application Configuration
NODE_ENV=development
API_PORT=3001
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173
COOKIE_DOMAIN=
JOB_CONCURRENCY=5
GRACE_PERIOD_HOURS=48

# Admin Configuration (comma-separated list of admin email addresses)
ADMIN_EMAILS=

# Security Configuration
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
TWO_FACTOR_ISSUER=HandoverKey

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@handoverkey.com
