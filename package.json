{
  "name": "handoverkey",
  "version": "1.1.3",
  "description": "A stupidly secure, open-source digital legacy platform with dead man's switch functionality",
  "private": true,
  "packageManager": "npm@11.6.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "docker:up": "docker-compose up -d postgres redis",
    "docker:prod": "docker-compose -f docker-compose.prod.yaml up -d --build",
    "docker:down": "docker-compose down",
    "db:migrate": "cd apps/api && npm run migrate",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^25.3.3",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.0",
    "turbo": "^2.8.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/handoverkey/handoverkey.git"
  },
  "keywords": [
    "digital-legacy",
    "dead-man-switch",
    "encryption",
    "security",
    "zero-knowledge",
    "open-source"
  ],
  "author": "HandoverKey Team",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/handoverkey/handoverkey/issues"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{js,jsx,json,md}": [
      "prettier --write"
    ]
  },
  "homepage": "https://handoverkey.com"
}
